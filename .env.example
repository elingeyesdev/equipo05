APP_NAME="Integracion Donaciones Fase 1"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Con PostgreSQL unificado (Docker): core + DB_CONNECTION=core
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=database/database.sqlite
DB_USERNAME=root
DB_PASSWORD=

# --- Modo base unificada PostgreSQL (un servidor, un schema por modulo) ---
# true = inventario, incendios, rescate, logistica, seguimiento, cuadrillas usan PG.
# Tablas en PG: scripts en database/unified_postgresql/ (Docker las aplica al crear el volumen).
# Guia DBeaver + Laravel: database/docker/CONEXION_DBEAVER_Y_LARAVEL.txt
#
# Perfil con Docker (db_unificado): pon DATABASE_UNIFIED_POSTGRES=true y estos valores:
DATABASE_UNIFIED_POSTGRES=false
# Si DATABASE_UNIFIED_POSTGRES=true, usa también:
# DB_CONNECTION=core
UNIFIED_PG_URL=
UNIFIED_PG_HOST=127.0.0.1
UNIFIED_PG_PORT=5433
UNIFIED_PG_DATABASE=equipo05_unificado
UNIFIED_PG_USERNAME=postgres
UNIFIED_PG_PASSWORD=equipo05_unificado_dev
UNIFIED_PG_CHARSET=utf8
UNIFIED_PG_SSLMODE=prefer
# Puerto que publica Compose en Windows (debe coincidir con UNIFIED_PG_PORT si usas el default):
UNIFIED_PG_DOCKER_PORT=5433
#
# Si usas PostgreSQL instalado en Windows (sin Docker), usa UNIFIED_PG_PORT=5432
# y la contrasena de tu usuario postgres local.

INVENTARIO_DB_DATABASE=database/inventario.sqlite
INCENDIOS_DB_DATABASE=database/incendios.sqlite
RESCATE_DB_DATABASE=database/rescate.sqlite
LOGISTICA_DB_DATABASE=database/logistica.sqlite
SEGUIMIENTO_DB_DATABASE=database/seguimiento.sqlite
CUADRILLAS_DB_DATABASE=database/cuadrillas.sqlite

# AQUI ESTA LA CLAVE: Declarar las variables vacías
API_DONACIONES_URL=
API_GATEWAY_URL=

# NASA FIRMS (mapa de calor; opcional: sin clave se usan datos de demostración)
FIRMS_API_KEY=
# API alternativa de hotspots (opcional; vacío = se omite y se usa demo si FIRMS no está)
FALLBACK_HOTSPOTS_URL=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"